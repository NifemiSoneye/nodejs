{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "rootDir": "./",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": [
    "server.ts",
    "config/**/*",
    "controllers/**/*",
    "middleware/**/*",
    "model/**/*",
    "routes/**/*"
  ],
  "exclude": ["node_modules", "dist", "logs", "public", "views"]
}
